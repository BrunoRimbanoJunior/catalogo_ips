{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "catalogo_ips",
  "version": "1.5.7",
  "identifier": "com.catalogo-ips",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Catálogo de Peças - IPS",
        "width": 1280,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob: https:; connect-src 'self' ipc: http://ipc.localhost https://*.supabase.co https://api.github.com https://github.com https://*.r2.dev https://*.cloudflarestorage.com; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": [
      "../data/catalog.db",
      "../manifest.json"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13",
      "bundleVersion": "10503"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/BrunoRimbanoJunior/catalogo_ips/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERGNUE5ODYxQ0E0QjcwNDUKUldSRmNFdktZWmhhMzc5WVRtTGtMQkVVVzBZRVdSd0pTand1RFNFZ1pWdFJIVXhaVU45eDlBS3MK"
    }
  }
}
